rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This rule allows an authenticated user to read and write documents
    // in their own subcollection within the 'users' collection.
    // The wildcard {userId} matches the authenticated user's ID.
    match /users/{userId}/{documents=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
